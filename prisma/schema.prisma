generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TrainingGroup {
  G1
  G2
  G3
}

enum TrainingMode {
  E
  D
}

enum EInvoiceConsent {
  TAK
  NIE
  NIE_POTRZEBUJE
}

model Submission {
  id               String   @id @default(cuid())
  createdAt        DateTime @default(now())

  term             String

  invoiceName      String?
  streetAndNumber  String?
  zipCity          String?
  nip              String?
  phone            String?
  invoiceEmail     String?
  otherAddress     String?
  eInvoiceConsent  EInvoiceConsent @default(NIE)

  heardFrom        String

  rodoConsent      Boolean
  infoObligation   Boolean

  participants     Participant[]
}

model Participant {
  id              String @id @default(cuid())
  submissionId    String
  submission      Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  fullName        String
  pesel           String?
  documentId      String?

  trainingScope   String?
  group           TrainingGroup?
  mode            TrainingMode?
  points          String?
}